test-*.html
verify-*.sh
verify-*.html

# 脚本备份
scripts/*.backup*

# 系统文件
.DS_Store
Thumbs.db

# IDE文件
.vscode/
.idea/
*.swp

# 环境文件
.env
.env.local
.env.*.local

# 构建文件
dist/
build/
node_modules/

